root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.gd]
indent_style = tab
indent_size = 4

[*.cs]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 2

[*.{md,yml,yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{tscn,tres,gdshader}]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = tab
indent_size = 4
